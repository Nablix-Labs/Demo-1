# Numera — environment variables
# Copy this file to .env.local and fill in real values before running

# Backend REST API base URL
# Local: http://127.0.0.1:8000
# Vercel/hosted: https://your-backend.example.com
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# WebSocket voice streaming endpoint
# Local: ws://127.0.0.1:8000/voice/stream
# Vercel/hosted: wss://your-backend.example.com/voice/stream
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000/voice/stream
