# Numera — environment variables
# Copy this file to .env.local and fill in real values before running

# Backend REST API base URL
NEXT_PUBLIC_API_BASE_URL=https://api.numera.nablix.com/v1

# WebSocket voice streaming endpoint
NEXT_PUBLIC_WS_URL=wss://api.numera.nablix.com/voice/stream
NEXT_PUBLIC_VOICE_WS_URL=wss://api.numera.nablix.com/voice/stream
NEXT_PUBLIC_ENABLE_VOICE_STREAMING=true

# Voice turn transport (see app/page.tsx):
#   rest (default) — browser does STT (Web Speech) and fires the turn over REST;
#                    the tutor reply is voiced by the browser (Web Speech).
#   server         — stream raw mic audio to the backend /voice/stream WebSocket.
NEXT_PUBLIC_VOICE_TRANSPORT=rest

# Testing only. The tutoring backend rejects /interaction, /hint, /canvas and
# /voice without a bearer token (401), but signing up doesn't log in to the auth
# server yet — so students who sign up have no token and those calls all fail.
# Set to "true" for test builds to send a placeholder bearer instead. A real
# token always wins over the placeholder. Remove once sign-up performs a real
# login.
NEXT_PUBLIC_ALLOW_ANON_TUTOR=false
